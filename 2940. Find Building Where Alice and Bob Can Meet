class Solution {
public:
vector<int>segTree;
   void sol(int i, int l, int r, vector<int>&nums){
            if(l==r){
                 segTree[i]=l;
                return ;
            }
            int mid=(l+r)/2;
             sol(2*i+1, l, mid, nums);
             sol(2*i+2, mid+1, r, nums);
             int left=segTree[2*i+1];
             int right=segTree[2*i+2];
             if(nums[left]>=nums[right]){
                 segTree[i]=left;
             }else{
               segTree[i]=right;
             }
   }
   int find_range(int st, int ed, int i, int l, int r, vector<int>&nums){
          if(l>ed || st>r){
                return -1;
          }
          if(st<=l && ed>=r){
                return segTree[i];
          }
           int mid=(l+r)/2;
          int left=find_range(st, ed, 2*i+1, l, mid, nums);
          int right=find_range(st, ed, 2*i+2, mid+1, r, nums);
              if(left==-1) return right;
              if(right==-1) return left;
              if(nums[left]>=nums[right]){
                   return left;
              }
              return right;
   }
     
    vector<int> leftmostBuildingQueries(vector<int>& heights, vector<vector<int>>& queries) 
    {      int n=heights.size();
          segTree.resize(4*n);
             sol(0, 0, n-1, heights);
                 vector<int> ans;
               for(auto x:queries){
                    int maxi_ind=max(x[0], x[1]);
                    int mini_ind=min(x[0], x[1]);
                    if(x[0]==x[1]){
                          ans.push_back(x[0]);
                    }else if(heights[mini_ind]<heights[maxi_ind]){
                          ans.push_back(maxi_ind);
                    }else{
                          int res=-1;
                         int l=maxi_ind+1;
                         int r=n-1;
                         while(l<=r){
                               int mid=(l+r)/2;
                               int ind=find_range(l, mid, 0, 0, n-1, heights);
                    if(ind!=-1 && heights[ind]>heights[x[0]] && heights[ind]>heights[x[1]]){
                             res=mid;
                             r=mid-1;
                    }else{
                           l=mid+1;
                    }
                         }
                         ans.push_back(res);
                          
                    }
               }
               return ans;
    }
};
